# pi-optimiser task manifest
# Defines the execution order for tasks in lib/tasks/*.sh.
# Lines are task IDs; # starts a comment; blank lines ignored.
# Tasks present in lib/tasks/ but missing here are appended at the end
# with a warning — drop-ins still run, just not in a curated slot.

# --- System upgrade (always runs first, every invocation) -------------
full_upgrade

# --- Cleanup & foundations -------------------------------------------
remove_bloat

# --- Kernel & runtime tuning -----------------------------------------
# apt_conf quiets apt-daily + sets Install-Recommends=0 BEFORE any task
# that does ensure_packages (zram, locale, cli_tools, unattended, ...),
# so installs don't pull unneeded suggests and a background apt-daily
# can't hold the dpkg lock. sysctl lands here too so its vm.* knobs are
# live before zram configures swap behaviour.
sysctl
cpu_governor
apt_conf
unattended
cli_tools
chrony

# --- Storage & filesystems -------------------------------------------
# zram uses ensure_packages (systemd-zram-generator) so it must run
# AFTER apt_conf. The rest of this block is pure fstab / systemd unit
# toggles and has no apt dependency.
fstab
tmpfs_tmp
journald
var_log_tmpfs
disable_swap
zram
fstrim
nvme_tune
usb_uas_quirks

# --- System identity --------------------------------------------------
locale
timezone
hostname
limits

# --- Display & background services -----------------------------------
screen_blanking
disable_services
quiet_boot
disable_leds
headless_gpu_mem

# --- Networking -------------------------------------------------------
proxy
dns_cache
wifi_bt_power
node_exporter
tailscale
wireguard
ipv6_disable

# --- Hardware & clocks ------------------------------------------------
boot_config
libliftoff
thermal_thresholds
oc_conservative
underclock
pi5_fan
pcie_gen3
eeprom_config
watchdog

# --- Security ---------------------------------------------------------
ssh_import
secure_ssh
ufw_firewall

# --- Packages ---------------------------------------------------------
cli_bundle_modern
net_diag_bundle
smartmontools

# --- Integrations -----------------------------------------------------
docker
pi_connect
hailo

# --- Firmware (reboot-required; runs last) ---------------------------
eeprom_refresh
firmware_update
power_off_halt
